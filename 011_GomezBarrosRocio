"""
Ejercicio 11: BATALLA DE HECHICEROS
Dos hechiceros se enfrentan en un duelo mágico. Uno será controlado por el usuario, quien podrá tomar
decisiones estratégicas durante el combate.
Cada acción tiene consecuencias sobre los recursos disponibles del personaje, por lo que será necesario
administrarlos correctamente.
El enfrentamiento continúa hasta que uno de los participantes ya no pueda seguir luchando.
"""
import random

class Hechicero:
    def __init__(self):
        self.cant_recursos = 100
        self.vidas = 5

    def atacar(self, enemigo):
        if self.cant_recursos >= 10:
            enemigo.vidas -= 1
            self.cant_recursos -= 10
        else:
            print("No tienes suficientes recursos para atacar")

    def curar(self):
        if self.cant_recursos >= 15:
            self.vidas += 1
            self.cant_recursos -= 15
        else:
            print("No tienes suficientes recursos para curarte")

def mostrar_estado():
    print("\n--------------------------------------------")
    print(f"Sistema → Vidas: {sistema.vidas} | Recursos: {sistema.cant_recursos}")
    print(f" Tú     → Vidas: {jugador.vidas} | Recursos: {jugador.cant_recursos}")
    print("\n--------------------------------------------")

jugador = Hechicero()
sistema = Hechicero()

while jugador.vidas > 0 and sistema.vidas > 0:
    print("\n--------------------------------------------")
    print("\n¿Que quieres hacer?")
    print("1- Atacar")
    print("2- Curarse")

    op = int(input("Ingrese: "))

    if op == 1:
        jugador.atacar(sistema)
    elif op == 2:
        jugador.curar()

    mostrar_estado()

    if sistema.vidas > 0:
        eleccion = random.randint(1, 2)
        if eleccion == 1:
            sistema.atacar(jugador)
            print("Te han atacado")
        elif eleccion == 2:
            sistema.curar()
            print("El otro hechicero se ha curado")

        mostrar_estado

if jugador.vidas > 0:
    print("¡FELICITACIONES! Ganaste el duelo.")
else:
    print("GAME OVER. El otro hechicero te ha derrotado.")